generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  spotifyId     String    @unique
  email         String?   @unique
  username      String?   @unique
  displayName   String?
  avatarUrl     String?
  country       String?
  bio           String?
  profileTheme  Json?
  isProfilePublic Boolean @default(true)
  passwordHash  String?
  
  // Music preferences
  favoriteGenres String[]
  
  // Relations
  reviews       Review[]
  playlists     Playlist[]
  likedTracks   LikedTrack[]
  albumReviews  AlbumReview[]
  songReviews   SongReview[]
  following     Follow[] @relation("UserFollows")
  followers     Follow[] @relation("UserFollowers")
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("UserFollows", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model AlbumReview {
  id                   String   @id @default(cuid())
  userId               String
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  spotifyAlbumId       String
  albumTitle           String
  albumArtists         Json
  albumImageUrl        String?
  releaseDate          String?
  releaseYear          Int?
  albumType            String?

  finalScore           Float
  trackAverage         Float?
  albumCategoryAverage Float?

  bestTrackTitle       String?
  weakestTrackTitle    String?

  reviewTitle          String?
  reviewBody           String?
  finalRecommendation  String?

  theme                Json?
  ratingData           Json
  slideData            Json?

  isDraft              Boolean  @default(false)
  isPublic             Boolean  @default(true)
  visibility           String   @default("public")

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([spotifyAlbumId])
  @@index([createdAt])
  @@index([visibility])
}

model SongReview {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  spotifyTrackId      String
  trackTitle          String
  trackArtists        Json
  albumId             String?
  albumTitle          String?
  imageUrl            String?
  durationMs          Int?

  finalScore          Float

  reviewTitle         String?
  reviewBody          String?
  finalRecommendation String?

  theme               Json?
  ratingData          Json
  slideData           Json?

  isDraft             Boolean  @default(false)
  isPublic            Boolean  @default(true)
  visibility          String   @default("public")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([spotifyTrackId])
  @@index([createdAt])
  @@index([visibility])
}

model Review {
  id          String   @id @default(cuid())
  
  // Track info (stored for quick access)
  trackId     String   // Spotify track ID
  trackName   String
  artistName  String
  albumName   String
  albumArt    String?
  
  // Review content
  rating      Float    // 0.5 to 5.0 stars (like Letterboxd)
  content     String?  // Text review (optional)
  
  // Audio features at time of review
  tempo       Float?
  key         Int?
  energy      Float?
  danceability Float?
  valence     Float?   // Musical positivity
  
  // Relations
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Likes on review
  likesCount  Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([userId, trackId])
  @@index([trackId])
  @@index([rating])
}

model Playlist {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // Can be synced to Spotify
  spotifyPlaylistId String?
  
  // Playlist tracks
  tracks      PlaylistTrack[]
  
  // Owner
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isPublic    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlaylistTrack {
  id          String   @id @default(cuid())
  
  trackId     String   // Spotify track ID
  trackName   String
  artistName  String
  albumArt    String?
  
  position    Int
  
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  
  addedAt     DateTime @default(now())
  
  @@unique([playlistId, trackId])
}

model LikedTrack {
  id          String   @id @default(cuid())
  
  trackId     String   // Spotify track ID
  trackName   String
  artistName  String
  albumArt    String?
  
  // Audio features
  tempo       Float?
  key         Int?
  energy      Float?
  danceability Float?
  valence     Float?
  genres      String[]
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  likedAt     DateTime @default(now())
  
  @@unique([userId, trackId])
}
