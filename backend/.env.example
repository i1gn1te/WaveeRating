# Server Environment Variables
# Copy this file to .env and fill in your values

# Database
# Local PostgreSQL example:
# create database waveeRating, then replace YOUR_PASSWORD with your postgres password.
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/waveeRating?schema=public"

# Spotify API - Get Client ID/Secret from https://developer.spotify.com/dashboard
# Spotify app: WaveeRating
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://127.0.0.1:3001/api/auth/callback"
SPOTIFY_REDIRECT_URIS="https://waveebw.vercel.app/api/auth/callback,https://waveebw-production.up.railway.app/api/auth/callback,http://127.0.0.1:3001/api/auth/callback"

# JWT Secret - Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_random_32_byte_hex_secret"

# Frontend URL / CORS origin
FRONTEND_URL="http://localhost:5173"
CLIENT_URL="http://localhost:5173"

# Server Port
PORT=3001
NODE_ENV=development
